<Window x:Class="SnapCat.App.Windows.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapCat 更新"
        Width="440"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Track x:Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{TemplateBinding Foreground}"
                                                  BorderThickness="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent"
                                                  BorderThickness="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource Theme.Brush.WindowBackground}"
            BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="正在更新 SnapCat" />
                    <TextBlock x:Name="VersionTextBlock"
                               Margin="0,5,0,0"
                               Foreground="{DynamicResource Theme.Brush.TextMuted}"
                               Text="正在准备更新" />
                </StackPanel>
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Margin="14,0,0,0"
                        Click="CloseButton_OnClick"
                        Content="×"
                        FontSize="18"
                        IsEnabled="False"
                        Style="{StaticResource CloseButtonStyle}" />
            </Grid>
            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <Grid>
                        <TextBlock FontWeight="SemiBold" Text="升级进度" />
                        <TextBlock x:Name="PercentTextBlock"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Theme.Brush.Highlight}" />
                    </Grid>
                    <ProgressBar x:Name="UpdateProgressBar"
                                 Margin="0,12,0,0"
                                 Maximum="100"
                                 Minimum="0"
                                 Style="{StaticResource ProgressBarStyle}" />
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <TextBlock Grid.Row="2"
                       Margin="0,14,0,0"
                       Foreground="{DynamicResource Theme.Brush.TextMuted}"
                       Text="下载、校验和解压完成后，SnapCat 会自动退出并完成覆盖升级。"
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
