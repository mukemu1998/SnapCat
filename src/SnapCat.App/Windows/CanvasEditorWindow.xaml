<Window x:Class="SnapCat.App.Windows.CanvasEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画布编辑"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_OnLoaded"
        KeyDown="Window_OnKeyDown">
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryToolButtonStyle"
               BasedOn="{StaticResource ToolButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,0,28,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="10"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  IsHitTestVisible="False" />
                                                <Path Width="8"
                                                      Height="4"
                                                      Margin="0,0,12,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{DynamicResource Theme.Brush.TextMuted}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.58" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Margin="0,6,0,0"
                                            Padding="5"
                                            Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CanvasSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource Theme.Brush.Accent}"
                                BorderBrush="{DynamicResource Theme.Brush.AccentBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Theme.Brush.Highlight}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Theme.Brush.Highlight}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource Theme.Brush.Accent}"
                                                        CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CanvasSliderThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource Theme.Brush.ButtonBorder}"
                                                        Opacity="0.72"
                                                        CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="#66000000">
        <Border x:Name="EditorSurfaceHost"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource Theme.Brush.AccentBorder}"
                BorderThickness="1"
                Background="#111111">
            <Grid x:Name="EditorSurface"
                  ClipToBounds="True"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                <Image x:Name="BackgroundImage"
                       Stretch="Fill"
                       SnapsToDevicePixels="True" />
                <Canvas x:Name="ShapeCanvas"
                        Background="Transparent" />
                <InkCanvas x:Name="InkLayer"
                           Background="Transparent"
                           EditingMode="Ink"
                           UseCustomCursor="False"
                           PreviewMouseLeftButtonDown="InkLayer_OnPreviewMouseLeftButtonDown"
                           PreviewMouseMove="InkLayer_OnPreviewMouseMove"
                           PreviewMouseLeftButtonUp="InkLayer_OnPreviewMouseLeftButtonUp"
                           StrokeCollected="InkLayer_OnStrokeCollected" />
            </Grid>
        </Border>

        <Border x:Name="Toolbar"
                Width="760"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="18"
                MouseLeftButtonDown="Toolbar_OnMouseLeftButtonDown"
                MouseMove="Toolbar_OnMouseMove"
                MouseLeftButtonUp="Toolbar_OnMouseLeftButtonUp">
            <StackPanel>
                <WrapPanel HorizontalAlignment="Center">
                    <Button x:Name="SelectToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Select" Click="ToolButton_OnClick" Content="框选" />
                    <Button x:Name="LineToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Line" Click="ToolButton_OnClick" Content="直线" />
                    <Button x:Name="ArrowToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Arrow" Click="ToolButton_OnClick" Content="箭头" Visibility="Collapsed" />
                    <Button x:Name="PenToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Pen" Click="ToolButton_OnClick" Content="画笔" />
                    <Button x:Name="MarkerToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Marker" Click="ToolButton_OnClick" Content="马克笔" />
                    <Button x:Name="MosaicToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Mosaic" Click="ToolButton_OnClick" Content="马赛克" />
                    <Button x:Name="EraserToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Eraser" Click="ToolButton_OnClick" Content="橡皮" />
                    <Button x:Name="TextToolButton" Style="{StaticResource ToolButtonStyle}" Tag="Text" Click="ToolButton_OnClick" Content="文本" />
                    <Button x:Name="UndoToolButton" Style="{StaticResource ToolButtonStyle}" Click="UndoButton_OnClick" Content="上一步" />
                    <Button x:Name="RedoToolButton" Style="{StaticResource ToolButtonStyle}" Click="RedoButton_OnClick" Content="下一步" />
                    <Button x:Name="ClearCanvasButton" Style="{StaticResource ToolButtonStyle}" Click="ClearCanvasButton_OnClick" Content="清屏" />
                    <Button x:Name="SaveButton" Style="{StaticResource ToolButtonStyle}" Click="SaveButton_OnClick" Content="保存" />
                    <Button x:Name="SaveAsButton" Style="{StaticResource ToolButtonStyle}" Click="SaveAsButton_OnClick" Content="另存" />
                    <Button x:Name="CancelToolButton" Style="{StaticResource ToolButtonStyle}" Click="CancelButton_OnClick" Content="取消" />
                </WrapPanel>

                <WrapPanel x:Name="ToolOptionsPanel"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center">
                    <StackPanel x:Name="StrokePatternPanel"
                                Orientation="Horizontal"
                                Margin="0,0,18,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="线型" />
                        <ComboBox x:Name="StrokePatternComboBox"
                                  Width="92"
                                  Height="30"
                                  Margin="8,0,0,0"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Solid" Content="实线" />
                            <ComboBoxItem Tag="Dashed" Content="虚线" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="ShapeKindPanel"
                                Orientation="Horizontal"
                                Margin="0,0,18,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="形状" />
                        <ComboBox x:Name="ShapeKindComboBox"
                                  Width="92"
                                  Height="30"
                                  Margin="8,0,0,0"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Rectangle" Content="矩形" />
                            <ComboBoxItem Tag="Ellipse" Content="椭圆" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="ArrowKindPanel"
                                Orientation="Horizontal"
                                Margin="0,0,18,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="类型" />
                        <ComboBox x:Name="ArrowKindComboBox"
                                  Width="118"
                                  Height="30"
                                  Margin="8,0,0,0"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Line" Content="直线" />
                            <ComboBoxItem Tag="ThinArrow" Content="细箭头" />
                            <ComboBoxItem Tag="FilledArrow" Content="实心箭头" />
                            <ComboBoxItem Tag="OutlineArrow" Content="空心箭头" />
                        </ComboBox>
                    </StackPanel>

                    <TextBlock x:Name="ColorLabel"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               Text="颜色" />
                    <StackPanel x:Name="ColorSourcePanel"
                                Orientation="Horizontal"
                                Margin="8,0,8,0">
                        <Button x:Name="ThemeColorSourceButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Width="54"
                                Height="30"
                                Margin="0,0,4,0"
                                Click="ThemeColorSourceButton_OnClick"
                                Content="主题" />
                        <Button x:Name="PaletteColorSourceButton"
                                Style="{StaticResource ToolButtonStyle}"
                                Width="54"
                                Height="30"
                                Margin="0"
                                Click="PaletteColorSourceButton_OnClick"
                                Content="色板" />
                    </StackPanel>
                    <ComboBox x:Name="ColorComboBox"
                              Width="92"
                              Height="30"
                              Margin="0,0,18,0"
                              SelectedIndex="0"
                              SelectionChanged="ColorComboBox_OnSelectionChanged">
                        <ComboBoxItem Tag="ThemeAccent" Content="主题色" />
                        <ComboBoxItem Tag="#FF22D3EE" Content="青色" />
                        <ComboBoxItem Tag="#FFEF4444" Content="红色" />
                        <ComboBoxItem Tag="#FFFACC15" Content="黄色" />
                        <ComboBoxItem Tag="#FFFFFFFF" Content="白色" />
                        <ComboBoxItem Tag="#FF111827" Content="黑色" />
                    </ComboBox>
                    <Button x:Name="CustomColorButton"
                            Style="{StaticResource ToolButtonStyle}"
                            Width="78"
                            Height="30"
                            Margin="0,0,18,0"
                            Click="CustomColorButton_OnClick"
                            Content="打开色板"
                            Visibility="Collapsed" />

                    <TextBlock x:Name="ThicknessLabel"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               Text="粗细" />
                    <Slider x:Name="ThicknessSlider"
                            Width="130"
                            Minimum="2"
                            Maximum="36"
                            Value="6"
                            Margin="8,0,0,0"
                            ValueChanged="ThicknessSlider_OnValueChanged" />

                    <StackPanel x:Name="MosaicKindPanel"
                                Orientation="Horizontal"
                                Margin="18,0,0,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="马赛克" />
                        <ComboBox x:Name="MosaicKindComboBox"
                                  Width="104"
                                  Height="30"
                                  Margin="8,0,0,0"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Block" Content="方块" />
                            <ComboBoxItem Tag="Soft" Content="柔和" />
                            <ComboBoxItem Tag="Heavy" Content="强遮挡" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="FontPanel"
                                Orientation="Horizontal"
                                Margin="18,0,0,0">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="字体" />
                        <ComboBox x:Name="FontFamilyComboBox"
                                  Width="120"
                                  Height="30"
                                  Margin="8,0,8,0"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Microsoft YaHei UI" Content="微软雅黑" />
                            <ComboBoxItem Tag="SimHei" Content="黑体" />
                            <ComboBoxItem Tag="KaiTi" Content="楷体" />
                            <ComboBoxItem Tag="Segoe UI" Content="Segoe UI" />
                        </ComboBox>
                        <ComboBox x:Name="FontWeightComboBox"
                                  Width="86"
                                  Height="30"
                                  SelectedIndex="0"
                                  SelectionChanged="ToolOption_OnSelectionChanged">
                            <ComboBoxItem Tag="Normal" Content="常规" />
                            <ComboBoxItem Tag="Bold" Content="加粗" />
                        </ComboBox>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
