<Window x:Class="SnapCat.App.Windows.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560"
        Height="620"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    <Grid Background="Transparent"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Image Width="512"
                   Height="512"
                   Source="{DynamicResource Theme.Image.AppLogo}"
                   Stretch="Uniform">
                <Image.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="8"
                                      Opacity="0.28"
                                      Color="#FF000000" />
                </Image.Effect>
            </Image>

            <Border Margin="0,2,0,0"
                    Padding="20,7"
                    HorizontalAlignment="Center"
                    Background="#AA111827"
                    CornerRadius="18">
                <TextBlock x:Name="LoadingTextBlock"
                           MinWidth="76"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FFF8FAFC"
                           Text="加载中"
                           TextAlignment="Center" />
            </Border>
        </StackPanel>
    </Grid>
</Window>
