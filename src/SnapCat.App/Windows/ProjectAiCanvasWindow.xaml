<Window x:Class="SnapCat.App.Windows.ProjectAiCanvasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="AI 创作画布"
        Width="1360"
        Height="860"
        MinWidth="960"
        MinHeight="640"
        AllowsTransparency="False"
        AllowDrop="True"
        Background="{DynamicResource Theme.Brush.WindowBackground}"
        DragOver="Window_OnDragOver"
        Drop="Window_OnDrop"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        SizeChanged="Window_OnSizeChanged"
        StateChanged="Window_OnStateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="76"
                           ResizeBorderThickness="8"
                           CornerRadius="12"
                           GlassFrameThickness="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>
        <Style x:Key="CanvasContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Padding="6"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter VerticalAlignment="Center"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasContextMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="6,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{DynamicResource Theme.Brush.ButtonBorder}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryCanvasButtonStyle"
               BasedOn="{StaticResource CanvasButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="CloseButtonStyle"
               BasedOn="{StaticResource CanvasButtonStyle}"
               TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>
        <Style x:Key="WindowControlButtonStyle"
               BasedOn="{StaticResource CanvasButtonStyle}"
               TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="CanvasTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ReadOnlyBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,0,32,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ReadOnlyBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="10">
                                            <Grid>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Width="8" Height="4" Margin="0,0,12,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource Theme.Brush.TextSecondary}" StrokeThickness="1.5" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border MinWidth="{TemplateBinding ActualWidth}" Margin="0,6,0,0" Padding="5"
                                        Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                        BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                        BorderThickness="1" CornerRadius="10">
                                    <ScrollViewer MaxHeight="220"><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="1"
                                Background="{DynamicResource Theme.Brush.ScrollThumb}"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Height" Value="4" />
            <Setter Property="MinHeight" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Margin="1,2"
                                Background="{DynamicResource Theme.Brush.ScrollTrack}"
                                CornerRadius="3">
                            <Track x:Name="PART_Track"
                                   Orientation="{TemplateBinding Orientation}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Value="{Binding Value, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CanvasScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CanvasReferenceListBoxStyle" TargetType="ListBox">
            <Setter Property="Padding" Value="3" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          Padding="{TemplateBinding Padding}"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource CanvasScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="0"
             Padding="16"
             Background="{DynamicResource Theme.Brush.WindowBackground}"
             BorderThickness="0"
             CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="AI 创作画布" />
                    <TextBlock x:Name="ProjectNameTextBlock"
                               Margin="0,5,0,0"
                               Foreground="{DynamicResource Theme.Brush.TextMuted}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_OnClick"
                            Content="−"
                            FontSize="18"
                            Style="{StaticResource WindowControlButtonStyle}" />
                    <Button x:Name="MaximizeRestoreButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeRestoreButton_OnClick"
                            Content="□"
                            FontSize="16"
                            Style="{StaticResource WindowControlButtonStyle}" />
                    <Button shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_OnClick"
                            Content="×"
                            FontSize="18"
                            Style="{StaticResource CloseButtonStyle}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,16,0,12"
                    Padding="10"
                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <DockPanel LastChildFill="False">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               Text="中键拖动画布，滚轮缩放；拖动素材卡片可调整位置。" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Click="ResetViewportButton_OnClick"
                                Content="还原视图"
                                Style="{StaticResource CanvasButtonStyle}" />
                        <Button Click="SaveCanvasButton_OnClick"
                                Content="保存画布"
                                Style="{StaticResource PrimaryCanvasButtonStyle}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="InspectorColumn" Width="308" />
                </Grid.ColumnDefinitions>
                <Border Background="{DynamicResource Theme.Brush.SurfaceAltBackground}"
                         BorderThickness="0"
                         CornerRadius="0"
                         ClipToBounds="True">
                    <Grid Background="{DynamicResource Theme.Brush.WindowBackground}">
                        <Canvas x:Name="CanvasViewport"
                                Background="{DynamicResource Theme.Brush.WindowBackground}"
                                AllowDrop="True"
                                DragOver="CanvasViewport_OnDragOver"
                                Drop="CanvasViewport_OnDrop"
                                Focusable="True"
                                MouseDown="CanvasViewport_OnMouseDown"
                                MouseMove="CanvasViewport_OnMouseMove"
                                MouseUp="CanvasViewport_OnMouseUp"
                                MouseWheel="CanvasViewport_OnMouseWheel"
                                SizeChanged="CanvasViewport_OnSizeChanged">
                            <Canvas x:Name="CanvasSurface"
                                    Width="4000"
                                    Height="3000"
                                    Background="{DynamicResource Theme.Brush.WindowBackground}">
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1" />
                                        <TranslateTransform x:Name="CanvasTranslateTransform" X="0" Y="0" />
                                    </TransformGroup>
                                </Canvas.RenderTransform>
                            </Canvas>
                        </Canvas>
                        <Border x:Name="CanvasNavigatorBorder"
                                Width="174"
                                Height="124"
                                Margin="0,0,14,14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Padding="7"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="Visible">
                            <Canvas x:Name="CanvasNavigatorSurface"
                                    Width="160"
                                    Height="110"
                                    Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="CanvasNavigatorSurface_OnMouseLeftButtonDown" />
                        </Border>
                        <Border x:Name="QuickGenerationComposer"
                                Width="720"
                                Margin="16,0,206,14"
                                Padding="12"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                AllowDrop="True"
                                DragOver="QuickGenerationComposer_OnDragOver"
                                Drop="QuickGenerationComposer_OnDrop"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid MaxWidth="760" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Text="快速生成" />
                                        <TextBlock Margin="8,1,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                                   Text="默认单图" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Click="ToggleAdvancedGenerationButton_OnClick"
                                            Content="高级参数"
                                            Style="{StaticResource CanvasButtonStyle}" />
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                    <TextBox x:Name="CanvasPromptTextBox"
                                             MinHeight="50"
                                             MaxHeight="96"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="CanvasPromptTextBox_OnTextChanged"
                                             ToolTip="描述想要创作的内容；可引用第 1 张、第 2 张参考图。"
                                             Style="{StaticResource CanvasTextBoxStyle}" />
                                    <TextBlock x:Name="CanvasPromptHintTextBlock"
                                               Margin="13,10,42,8"
                                               VerticalAlignment="Top"
                                               Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                               IsHitTestVisible="False"
                                               Text="描述想要创作的内容；可添加多张参考图，并在提示词中说明第几张参考图的用途。"
                                               TextWrapping="Wrap" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="ImportReferenceAssetsButton_OnClick"
                                            Content="+ 参考图"
                                            Style="{StaticResource CanvasButtonStyle}" />
                                    <ComboBox x:Name="GenerationProfileComboBox"
                                              Grid.Column="1"
                                              Margin="0,0,8,0"
                                              DisplayMemberPath="Name"
                                              Style="{StaticResource CanvasComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource CanvasComboBoxItemStyle}" />
                                    <ComboBox x:Name="CanvasAspectRatioComboBox"
                                              Grid.Column="2"
                                              Margin="0,0,8,0"
                                              Style="{StaticResource CanvasComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource CanvasComboBoxItemStyle}">
                                        <ComboBoxItem Tag="1:1" Content="比例 1:1" />
                                        <ComboBoxItem Tag="16:9" Content="比例 16:9" />
                                        <ComboBoxItem Tag="9:16" Content="比例 9:16" />
                                        <ComboBoxItem Tag="4:3" Content="比例 4:3" />
                                        <ComboBoxItem Tag="3:4" Content="比例 3:4" />
                                    </ComboBox>
                                    <Button x:Name="CancelCanvasGenerationButton"
                                            Grid.Column="3"
                                            Click="CancelCanvasGenerationButton_OnClick"
                                            Content="取消"
                                            IsEnabled="False"
                                            Style="{StaticResource CanvasButtonStyle}" />
                                    <Button x:Name="GenerateOnCanvasButton"
                                            Grid.Column="4"
                                            Click="GenerateOnCanvasButton_OnClick"
                                            Content="生成"
                                            Style="{StaticResource PrimaryCanvasButtonStyle}" />
                                </Grid>
                                <Border x:Name="AdvancedGenerationOptionsBorder"
                                        Grid.Row="3"
                                        Margin="0,10,0,0"
                                        Padding="10"
                                        Background="{DynamicResource Theme.Brush.SurfaceAltBackground}"
                                        BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Margin="0,0,8,0">
                                            <TextBox x:Name="CanvasNegativePromptTextBox"
                                                     MinHeight="42"
                                                     MaxHeight="72"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     TextChanged="CanvasNegativePromptTextBox_OnTextChanged"
                                                     ToolTip="负面提示词"
                                                     Style="{StaticResource CanvasTextBoxStyle}" />
                                            <TextBlock x:Name="CanvasNegativePromptHintTextBlock"
                                                       Margin="13,10,42,8"
                                                       VerticalAlignment="Top"
                                                       Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                                       IsHitTestVisible="False"
                                                       Text="可选：填写不希望出现在画面中的内容，例如模糊、低清晰度或多余肢体。"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                        <ComboBox x:Name="CanvasReferenceIntentComboBox"
                                                  Grid.Column="1"
                                                  Margin="0,0,8,0"
                                                  Style="{StaticResource CanvasComboBoxStyle}"
                                                  ItemContainerStyle="{StaticResource CanvasComboBoxItemStyle}">
                                            <ComboBoxItem Tag="综合参考" Content="综合参考" />
                                            <ComboBoxItem Tag="主体参考" Content="主体参考" />
                                            <ComboBoxItem Tag="风格参考" Content="风格参考" />
                                            <ComboBoxItem Tag="构图参考" Content="构图参考" />
                                        </ComboBox>
                                        <ComboBox x:Name="CanvasOutputCountComboBox"
                                                  Grid.Column="2"
                                                  Style="{StaticResource CanvasComboBoxStyle}"
                                                  ItemContainerStyle="{StaticResource CanvasComboBoxItemStyle}">
                                            <ComboBoxItem Tag="1" Content="结果 1 张" />
                                            <ComboBoxItem Tag="2" Content="结果 2 张" />
                                            <ComboBoxItem Tag="4" Content="结果 4 张" />
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border x:Name="InspectorBorder"
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        Padding="12"
                        Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                        BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel x:Name="InspectorTitlePanel">
                                <TextBlock FontWeight="SemiBold" Text="参考图" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                           Text="按顺序用于后续生成描述" />
                            </StackPanel>
                            <Button x:Name="ToggleInspectorButton"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Click="ToggleInspectorButton_OnClick"
                                    Content="收起"
                                    Style="{StaticResource CanvasButtonStyle}" />
                        </Grid>
                        <Grid x:Name="InspectorContentGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ListBox x:Name="ReferenceAssetsListBox"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                                 PreviewMouseLeftButtonDown="ReferenceAssetsListBox_OnPreviewMouseLeftButtonDown"
                                 PreviewMouseMove="ReferenceAssetsListBox_OnPreviewMouseMove"
                                 SelectionChanged="ReferenceAssetsListBox_OnSelectionChanged"
                                 SelectionMode="Extended"
                                 Style="{StaticResource CanvasReferenceListBoxStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <primitives:UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Height" Value="150" />
                                    <Setter Property="Padding" Value="6" />
                                    <Setter Property="Margin" Value="4" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="9">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid Height="86">
                                            <Border CornerRadius="7"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource Theme.Brush.WindowBackground}">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            </Border>
                                            <Border Margin="5"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="{DynamicResource Theme.Brush.Accent}"
                                                    CornerRadius="6">
                                                <TextBlock FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Theme.Brush.AccentText}"
                                                           Text="{Binding ReferenceOrderLabel}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Margin="2,7,2,0"
                                                   FontWeight="SemiBold"
                                                   FontSize="11"
                                                   Text="{Binding Title}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="32"
                                                   ToolTip="{Binding Title}" />
                                        <TextBlock Margin="2,3,2,0"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="28"
                                                   ToolTip="{Binding Summary}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                    Margin="0,0,6,0"
                                    Click="ImportReferenceAssetsButton_OnClick"
                                    Content="导入"
                                    Style="{StaticResource CanvasButtonStyle}" />
                            <Button x:Name="RemoveReferenceButton"
                                    Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Click="RemoveReferenceButton_OnClick"
                                    Content="移除"
                                    IsEnabled="False"
                                    Style="{StaticResource CanvasButtonStyle}" />
                        </Grid>
                        <Border Grid.Row="2"
                                Margin="0,12,0,0"
                                Height="144"
                                CornerRadius="10"
                                ClipToBounds="True"
                                Background="{DynamicResource Theme.Brush.SurfaceAltBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1">
                            <Image x:Name="ReferencePreviewImage" Stretch="Uniform" />
                        </Border>
                        </Grid>
                    </Grid>
                </Border>
                <Button x:Name="ExpandInspectorButton"
                        Grid.Column="0"
                        Margin="0,10,10,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="ExpandInspectorButton_OnClick"
                        Content="展开"
                        Visibility="Collapsed"
                        Style="{StaticResource CanvasButtonStyle}" />
            </Grid>

            <TextBlock x:Name="CanvasStatusTextBlock"
                       Grid.Row="3"
                       Margin="2,12,2,0"
                       Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                       Text="正在加载项目画布..."
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
