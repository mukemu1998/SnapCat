<Window x:Class="SnapCat.App.Windows.ProjectAssetCategoryDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="选择素材分类"
        Width="420"
        AllowsTransparency="False"
        Background="{DynamicResource Theme.Brush.WindowBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                           ResizeBorderThickness="0"
                           CornerRadius="12"
                           GlassFrameThickness="0"
                           UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>
        <Style x:Key="CategoryOptionStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Border Padding="18" Background="{DynamicResource Theme.Brush.WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="选择素材分类" />
                <TextBlock x:Name="DescriptionTextBlock" Margin="0,6,0,0" Foreground="{DynamicResource Theme.Brush.TextMuted}" TextWrapping="Wrap" />
            </StackPanel>
            <WrapPanel Grid.Row="1" Margin="0,18,0,8">
                <RadioButton x:Name="UnclassifiedRadioButton" Tag="Unclassified" IsChecked="True" Content="未分类" Style="{StaticResource CategoryOptionStyle}" />
                <RadioButton Tag="Character" Content="角色" Style="{StaticResource CategoryOptionStyle}" />
                <RadioButton Tag="Scene" Content="场景" Style="{StaticResource CategoryOptionStyle}" />
                <RadioButton Tag="Prop" Content="道具" Style="{StaticResource CategoryOptionStyle}" />
                <RadioButton Tag="StyleReference" Content="风格参考" Style="{StaticResource CategoryOptionStyle}" />
            </WrapPanel>
            <StackPanel Grid.Row="2" Margin="0,6,0,0">
                <TextBlock FontWeight="SemiBold" Text="自定义分类（可选）" />
                <TextBox x:Name="CustomCategoryTextBox"
                         Margin="0,8,0,0"
                         Padding="12,9"
                         Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                         BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                         BorderThickness="1"
                         Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                         MaxLength="40"
                         ToolTip="填写后会以此名称作为素材分类" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                           Text="填写自定义分类后会覆盖上方的内置分类名称。" />
            </StackPanel>
            <StackPanel Grid.Row="3" Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,10,0" Click="CancelButton_OnClick" Content="取消" IsCancel="True" Style="{StaticResource DialogButtonStyle}" />
                <Button x:Name="ConfirmButton" Click="ConfirmButton_OnClick" Content="确认导入" IsDefault="True" Style="{StaticResource PrimaryDialogButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
