<Window x:Class="SnapCat.App.Windows.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="252"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        SizeToContent="Height"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="MenuShortcutTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextMuted}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="7"
            Background="{DynamicResource Theme.Brush.WindowBackground}"
            BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
            BorderThickness="1"
            CornerRadius="18">
        <StackPanel>
            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowMainWindowButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示主菜单" />
                    <TextBlock x:Name="ShowMainWindowHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenHistoryButton_OnClick">
                <TextBlock Text="查看历史" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenSettingsButton_OnClick">
                <TextBlock Text="打开设置" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenCaptureDirectoryButton_OnClick">
                <TextBlock Text="打开截图目录" />
            </Button>

            <Border Height="1"
                    Margin="0,3,0,4"
                    Background="{DynamicResource Theme.Brush.Divider}" />

            <TextBlock Margin="4,0,4,4"
                       Foreground="{DynamicResource Theme.Brush.TextMuted}"
                       FontSize="10"
                       Text="贴图组" />

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowAllPinnedWindowsButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示全部贴图" />
                    <TextBlock x:Name="ShowAllPinnedHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="HideAllPinnedWindowsButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="隐藏全部贴图" />
                    <TextBlock x:Name="HideAllPinnedHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowUngroupedPinnedWindowsButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示未成组贴图" />
                    <TextBlock x:Name="ShowUngroupedPinnedHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowPinnedGroupOneButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示贴图组 1" />
                    <TextBlock x:Name="ShowPinnedGroupOneHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowPinnedGroupTwoButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示贴图组 2" />
                    <TextBlock x:Name="ShowPinnedGroupTwoHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowPinnedGroupThreeButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="显示贴图组 3" />
                    <TextBlock x:Name="ShowPinnedGroupThreeHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ExitButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="退出 SnapCat" />
                    <TextBlock x:Name="ExitApplicationHotkeyTextBlock"
                               Grid.Column="1"
                               Style="{StaticResource MenuShortcutTextStyle}" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
