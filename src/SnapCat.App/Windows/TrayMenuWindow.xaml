<Window x:Class="SnapCat.App.Windows.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="216"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        SizeToContent="Height"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,0,0,1" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="7"
            Background="{DynamicResource Theme.Brush.WindowBackground}"
            BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
            BorderThickness="1"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16"
                              ShadowDepth="4"
                              Opacity="0.24"
                              Color="{DynamicResource Theme.Color.Shadow}" />
        </Border.Effect>

        <StackPanel>
            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="CaptureAndPinButton_OnClick">
                <TextBlock Text="开始截图并固定到屏幕" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="CaptureAndTranslateButton_OnClick">
                <TextBlock Text="开始截图并自动翻译" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="CaptureAndWaitButton_OnClick">
                <TextBlock Text="开始截图后等待选择" />
            </Button>

            <Border Height="1"
                    Margin="0,3,0,3"
                    Background="{DynamicResource Theme.Brush.Divider}" />

            <TextBlock x:Name="CurrentActionSummaryTextBlock"
                       Margin="4,0,4,6"
                       Foreground="{DynamicResource Theme.Brush.TextMuted}"
                       FontSize="10" />

            <Button x:Name="PinActionButton"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="PinActionButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="设左键为固定到屏幕" />
                    <TextBlock x:Name="PinActionIndicator"
                               Grid.Column="1"
                               Foreground="{DynamicResource Theme.Brush.Highlight}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Grid>
            </Button>

            <Button x:Name="TranslateActionButton"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="TranslateActionButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="设左键为自动翻译" />
                    <TextBlock x:Name="TranslateActionIndicator"
                               Grid.Column="1"
                               Foreground="{DynamicResource Theme.Brush.Highlight}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Grid>
            </Button>

            <Button x:Name="WaitActionButton"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="WaitActionButton_OnClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="设左键为等待选择" />
                    <TextBlock x:Name="WaitActionIndicator"
                               Grid.Column="1"
                               Foreground="{DynamicResource Theme.Brush.Highlight}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Grid>
            </Button>

            <Border Height="1"
                    Margin="0,3,0,4"
                    Background="{DynamicResource Theme.Brush.Divider}" />

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ShowMainWindowButton_OnClick">
                <TextBlock Text="显示主菜单" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenHistoryButton_OnClick">
                <TextBlock Text="查看历史" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenSettingsButton_OnClick">
                <TextBlock Text="打开设置" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="OpenCaptureDirectoryButton_OnClick">
                <TextBlock Text="打开截图目录" />
            </Button>

            <Button Style="{StaticResource MenuButtonStyle}"
                    Click="ExitButton_OnClick">
                <TextBlock Text="退出 SnapCat" />
            </Button>
        </StackPanel>
    </Border>
</Window>
