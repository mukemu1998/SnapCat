<Window x:Class="SnapCat.App.Windows.OcrSelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize"
        ShowActivated="True"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        SnapsToDevicePixels="True"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="OcrContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Margin="6"
                                Padding="8"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="4"
                                                  Opacity="0.25"
                                                  Color="#FF000000" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        MinWidth="132"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Margin="0,0,0,2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Canvas x:Name="RootCanvas"
            Background="#01000000"
            ClipToBounds="True"
            Focusable="True"
            MouseLeftButtonDown="RootCanvas_OnMouseLeftButtonDown"
            MouseLeftButtonUp="RootCanvas_OnMouseLeftButtonUp"
            MouseMove="RootCanvas_OnMouseMove"
            MouseRightButtonDown="RootCanvas_OnMouseRightButtonDown">
        <Image x:Name="ScreenImage"
               IsHitTestVisible="False"
               Stretch="Fill"
               SnapsToDevicePixels="True" />

        <Rectangle x:Name="DimTop"
                   Fill="#A9000000"
                   IsHitTestVisible="False" />
        <Rectangle x:Name="DimLeft"
                   Fill="#A9000000"
                   IsHitTestVisible="False" />
        <Rectangle x:Name="DimRight"
                   Fill="#A9000000"
                   IsHitTestVisible="False" />
        <Rectangle x:Name="DimBottom"
                   Fill="#A9000000"
                   IsHitTestVisible="False" />

        <Canvas x:Name="TextLayer"
                IsHitTestVisible="False" />

        <Rectangle x:Name="SelectionFrame"
                   Fill="Transparent"
                   Stroke="{DynamicResource Theme.Brush.AccentBorder}"
                   StrokeThickness="2"
                   IsHitTestVisible="False" />

        <Border x:Name="StatusBadge"
                Padding="8,4"
                Background="#D51A1D24"
                BorderBrush="#88FFFFFF"
                BorderThickness="1"
                CornerRadius="6"
                IsHitTestVisible="False">
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#F4FFFFFF"
                       FontSize="12"
                       Text="识别中..." />
        </Border>

        <Border x:Name="MiniToolbar"
                Padding="8"
                Background="#D7282828"
                BorderBrush="#5CFFFFFF"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button Width="44"
                        Height="36"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CopyAllButton_OnClick"
                        Foreground="#FFFFFFFF"
                        FontSize="20"
                        ToolTip="复制识别文本"
                        Content="⧉" />
                <Button Width="44"
                        Height="36"
                        Margin="6,0,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="SelectAllButton_OnClick"
                        Foreground="#FFFFFFFF"
                        FontSize="18"
                        ToolTip="全选识别文本"
                        Content="▦" />
            </StackPanel>
        </Border>

        <Canvas.ContextMenu>
            <ContextMenu x:Name="OcrContextMenu"
                         Style="{StaticResource OcrContextMenuStyle}">
                <MenuItem x:Name="SelectAllMenuItem"
                          Header="全选"
                          Style="{StaticResource OcrContextMenuItemStyle}"
                          IsEnabled="False"
                          Click="SelectAllMenuItem_OnClick" />
                <MenuItem x:Name="CopyMenuItem"
                          Header="复制"
                          Style="{StaticResource OcrContextMenuItemStyle}"
                          IsEnabled="False"
                          Click="CopyMenuItem_OnClick" />
            </ContextMenu>
        </Canvas.ContextMenu>
    </Canvas>
</Window>
