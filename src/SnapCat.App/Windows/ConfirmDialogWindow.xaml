<Window x:Class="SnapCat.App.Windows.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作"
        Width="420"
        MinWidth="360"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogPrimaryButtonStyle"
               BasedOn="{StaticResource DialogButtonStyle}"
               TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Padding="18"
            Background="{DynamicResource Theme.Brush.WindowBackground}"
            BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="确认操作" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource Theme.Brush.TextMuted}"
                               Text="请确认是否继续执行。" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="34"
                        MinWidth="34"
                        Height="34"
                        Margin="14,0,0,0"
                        Padding="0"
                        Click="CancelButton_OnClick"
                        Content="×"
                        FontSize="16"
                        Style="{StaticResource DialogButtonStyle}" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Padding="14,12"
                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <TextBlock x:Name="MessageTextBlock"
                           Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                           LineHeight="24"
                           TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button x:Name="CancelButton"
                        Margin="0,0,10,0"
                        Click="CancelButton_OnClick"
                        Content="取消"
                        IsCancel="True"
                        Style="{StaticResource DialogButtonStyle}" />
                <Button x:Name="ConfirmButton"
                        Click="ConfirmButton_OnClick"
                        Content="确认"
                        IsDefault="True"
                        Style="{StaticResource DialogPrimaryButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
