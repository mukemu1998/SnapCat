<Window x:Class="SnapCat.App.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootSurface"
          Background="Transparent"
          MouseLeftButtonDown="RootSurface_OnMouseLeftButtonDown"
          MouseLeftButtonUp="RootSurface_OnMouseLeftButtonUp"
          MouseMove="RootSurface_OnMouseMove">
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="SelectionRectangle"
                       Stroke="{DynamicResource Theme.Brush.AccentBorder}"
                       Fill="{DynamicResource Theme.Brush.AccentSoft}"
                       StrokeThickness="2"
                       Visibility="Collapsed" />
        </Canvas>

        <Border Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="24">
            <TextBlock Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                       FontSize="14"
                       Text="拖动鼠标进行自由框选，松开后继续。按 Esc 取消。" />
        </Border>
    </Grid>
</Window>
