<Window x:Class="SnapCat.App.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SnapCat.App.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootSurface"
          Background="Transparent"
          MouseLeftButtonDown="RootSurface_OnMouseLeftButtonDown"
          MouseLeftButtonUp="RootSurface_OnMouseLeftButtonUp"
          PreviewMouseRightButtonDown="RootSurface_OnPreviewMouseRightButtonDown"
          PreviewMouseRightButtonUp="RootSurface_OnPreviewMouseRightButtonUp"
          MouseRightButtonDown="RootSurface_OnMouseRightButtonDown"
          MouseRightButtonUp="RootSurface_OnMouseRightButtonUp"
          MouseMove="RootSurface_OnMouseMove">
        <Grid IsHitTestVisible="False">
            <Image x:Name="SnapshotImage"
                   Stretch="Fill"
                   Visibility="Collapsed"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   SnapsToDevicePixels="True" />

            <controls:SelectionOverlayRenderLayer x:Name="OverlayLayer"
                                                  SmartPreviewStroke="{DynamicResource Theme.Brush.HighlightAlt}"
                                                  SmartPreviewFill="#10000000"
                                                  SelectionStroke="{DynamicResource Theme.Brush.AccentBorder}"
                                                  SelectionFill="{DynamicResource Theme.Brush.AccentSoft}" />

            <Border x:Name="ColorInspectorPanel"
                    Width="256"
                    Height="320"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CacheMode="BitmapCache"
                    Background="{DynamicResource Theme.Brush.WindowBackground}"
                    BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ColorInspectorTransform" />
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8"
                                      ShadowDepth="2"
                                      Opacity="0.18"
                                      Color="{DynamicResource Theme.Color.Shadow}" />
                </Border.Effect>

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="164" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="MagnifierImage"
                                   Stretch="Fill"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" />
                            <Rectangle Width="1"
                                       HorizontalAlignment="Center"
                                       Fill="{DynamicResource Theme.Brush.AccentBorder}" />
                            <Rectangle Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource Theme.Brush.AccentBorder}" />
                            <Border Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource Theme.Brush.TextPrimary}"
                                    BorderThickness="1"
                                    Background="#33000000" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="0,9,0,0"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="CoordinateTextBlock"
                                   HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Border x:Name="ColorPreviewSwatch"
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,10,0"
                                    BorderBrush="{DynamicResource Theme.Brush.TextPrimary}"
                                    BorderThickness="1" />
                            <TextBlock x:Name="ColorValueTextBlock"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="按 C 复制颜色值" />
                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="按 Shift 切换 RGB/HEX" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
