<Window x:Class="SnapCat.App.Windows.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootSurface"
          Background="Transparent"
          MouseLeftButtonDown="RootSurface_OnMouseLeftButtonDown"
          MouseLeftButtonUp="RootSurface_OnMouseLeftButtonUp"
          MouseRightButtonDown="RootSurface_OnMouseRightButtonDown"
          MouseMove="RootSurface_OnMouseMove">
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="SmartPreviewRectangle"
                       Stroke="{DynamicResource Theme.Brush.HighlightAlt}"
                       Fill="#18000000"
                       StrokeThickness="2"
                       StrokeDashArray="6 4"
                       Visibility="Collapsed" />

            <Rectangle x:Name="SelectionRectangle"
                       Stroke="{DynamicResource Theme.Brush.AccentBorder}"
                       Fill="{DynamicResource Theme.Brush.AccentSoft}"
                       StrokeThickness="2"
                       Visibility="Collapsed" />

            <Border x:Name="ColorInspectorPanel"
                    Width="256"
                    Height="320"
                    Background="{DynamicResource Theme.Brush.WindowBackground}"
                    BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16"
                                      ShadowDepth="4"
                                      Opacity="0.24"
                                      Color="{DynamicResource Theme.Color.Shadow}" />
                </Border.Effect>

                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="164" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <Grid>
                            <Image x:Name="MagnifierImage"
                                   Stretch="Fill"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True" />
                            <Rectangle Width="1"
                                       HorizontalAlignment="Center"
                                       Fill="{DynamicResource Theme.Brush.AccentBorder}" />
                            <Rectangle Height="1"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource Theme.Brush.AccentBorder}" />
                            <Border Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource Theme.Brush.TextPrimary}"
                                    BorderThickness="1"
                                    Background="#33000000" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="0,9,0,0"
                                HorizontalAlignment="Center">
                        <TextBlock x:Name="CoordinateTextBlock"
                                   HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        <StackPanel Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Border x:Name="ColorPreviewSwatch"
                                    Width="20"
                                    Height="20"
                                    Margin="0,0,10,0"
                                    BorderBrush="{DynamicResource Theme.Brush.TextPrimary}"
                                    BorderThickness="1" />
                            <TextBlock x:Name="ColorValueTextBlock"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="按 C 复制颜色值" />
                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="15"
                                   Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                   Text="按 Shift 切换 RGB/HEX" />
                    </StackPanel>
                </Grid>
            </Border>
        </Canvas>
    </Grid>
</Window>
