<Window x:Class="SnapCat.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SnapCat"
        Icon="{DynamicResource Theme.Image.AppLogo}"
        Background="Transparent"
        WindowStyle="None"
        Width="1320"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="SectionActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="CompactRoundedButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
        </Style>

        <Style x:Key="InlineIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.AccentSoft}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.AccentSoftPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainWindowScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="1"
                                Background="{DynamicResource Theme.Brush.TextMuted}"
                                Opacity="0.72"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CanContentScroll" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="2,0,0,0"
                                       Orientation="Vertical"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,2,0,0"
                                       Orientation="Horizontal"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />

                            <Border x:Name="ScrollCorner"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="2,2,0,0"
                                    Background="{DynamicResource Theme.Brush.ScrollTrack}"
                                    CornerRadius="4"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="ComputedVerticalScrollBarVisibility" Value="Visible" />
                                    <Condition Property="ComputedHorizontalScrollBarVisibility" Value="Visible" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ScrollCorner" Property="Visibility" Value="Visible" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="2" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent"
                                CornerRadius="3">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MainWindowScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="2" />
                                <Setter Property="VerticalAlignment" Value="Bottom" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.ReadOnlyBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PasswordBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="PasswordBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PasswordBoxBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent"
                                         SnapsToDevicePixels="True">
                            <BulletDecorator.Bullet>
                                <Border x:Name="CheckBoxBorder"
                                        Width="18"
                                        Height="18"
                                        Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                        BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <Grid>
                                        <Border x:Name="CheckedFill"
                                                Background="{DynamicResource Theme.Brush.Accent}"
                                                CornerRadius="4"
                                                Opacity="0" />
                                        <Path x:Name="CheckGlyph"
                                              Width="10"
                                              Height="8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 1 4 L 4 7 L 9 1"
                                              Stroke="{DynamicResource Theme.Brush.TextPrimary}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              ContentSource="Content"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckedFill" Property="Opacity" Value="1" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,0,40,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="12"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  IsHitTestVisible="False" />
                                                <Path Width="8"
                                                      Height="4"
                                                      Margin="0,0,14,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{DynamicResource Theme.Brush.TextMuted}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.6" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Margin="0,6,0,0"
                                            Padding="6"
                                            Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Padding="8"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="4"
                                                  Opacity="0.25"
                                                  Color="#FF000000" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        MinWidth="150"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Margin="0,0,0,2"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainContextMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="6,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{DynamicResource Theme.Brush.ButtonBorder}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="HistoryListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Padding" Value="0,0,2,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Style="{StaticResource HistoryScrollViewerStyle}"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2"
                                    Margin="0,10,0,0"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14" />
                            <Border Margin="16,0,16,0"
                                    Padding="10,0"
                                    Background="{DynamicResource Theme.Brush.WindowBackground}"
                                    HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              Margin="14,18,14,14" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid Margin="12,6,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Width="18"
                           Height="18"
                           Source="{DynamicResource Theme.Image.AppLogo}"
                           Stretch="Uniform" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="SnapCat" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="MinimizeButton_OnClick"
                            Content="-" />
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="MaximizeRestoreButton_OnClick"
                            Content="□" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="CloseWindowButton_OnClick"
                            Content="×" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="SnapCat" />
                    <TextBlock x:Name="VersionTextBlock"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource Theme.Brush.TextMuted}" />
                    <TextBlock Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               Text="自由框选截图、OCR、翻译和贴图操作现在都在一个主窗口里整理查看。" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,22,0,0"
                              Style="{StaticResource HistoryScrollViewerStyle}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,0,2,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                    <Border Padding="12"
                            Background="{DynamicResource Theme.Brush.CardBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.Highlight}"
                                       Text="核心功能" />
                            <Button x:Name="OcrNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="OcrSettings"
                                    Click="NavigationButton_OnClick">OCR 设置</Button>
                            <Button x:Name="TranslationNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="TranslationSettings"
                                    Click="NavigationButton_OnClick">翻译设置</Button>
                            <Button x:Name="HistoryNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="History"
                                    Click="NavigationButton_OnClick">历史记录</Button>
                            <Button x:Name="ScreenshotManagementNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="ScreenshotManagement"
                                    Click="NavigationButton_OnClick">截图管理</Button>
                            <Button x:Name="PinnedImagesNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="PinnedImages"
                                    Click="NavigationButton_OnClick">贴图管理</Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="{DynamicResource Theme.Brush.CardBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.Highlight}"
                                       Text="执行操作与快捷键" />
                            <Button x:Name="ExecuteActionsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="ExecuteActions"
                                    Click="NavigationButton_OnClick">操作快捷键</Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="{DynamicResource Theme.Brush.CardBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.HighlightAlt}"
                                       Text="系统设置" />
                            <Button x:Name="CaptureSettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="CaptureSettings"
                                    Click="NavigationButton_OnClick">系统快捷键</Button>
                            <Button x:Name="AppearanceSettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="AppearanceSettings"
                                    Click="NavigationButton_OnClick">外观主题</Button>
                            <Button x:Name="TraySettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="TraySettings"
                                    Click="NavigationButton_OnClick">托盘与启动</Button>
                            <Button x:Name="StatusNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="Status"
                                    Click="NavigationButton_OnClick">运行状态</Button>
                        </StackPanel>
                    </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="4"
                        Margin="0,16,0,0"
                        Padding="12"
                        Background="{DynamicResource Theme.Brush.CardBackground}"
                        BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="左侧只负责切换分类，右侧直接显示当前内容，不再弹出新的设置窗口。" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SectionTitleTextBlock"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        <TextBlock x:Name="SectionDescriptionTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top">
                        <Button x:Name="SaveSettingsButton"
                                Style="{StaticResource RoundedButtonStyle}"
                                Width="122"
                                Height="38"
                                Margin="0,0,10,0"
                                Visibility="Collapsed"
                                Click="SaveSettingsButton_OnClick">保存当前设置</Button>
                        <Button x:Name="CaptureButton"
                                Style="{StaticResource RoundedButtonStyle}"
                                Width="0"
                                Height="0"
                                MinWidth="0"
                                Padding="0"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                Click="CaptureButton_OnClick">开始自由框选</Button>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <ScrollViewer x:Name="StatusSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel>
                            <Border Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="当前配置摘要" />
                                    <TextBlock x:Name="SettingsSummaryTextBlock"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="#FF172033"
                                    BorderBrush="#FF3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock x:Name="EnvironmentCheckTitleTextBlock"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Text="启动检查" />
                                    <TextBlock x:Name="EnvironmentCheckTextBlock"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="使用建议" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="功能项类主要放 OCR、翻译和历史记录；系统设置类主要放快捷键、外观、托盘和运行状态。你现在可以在同一个窗口里完成查看、修改、测试和保存。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="OcrSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="OcrEngineLabelTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="OCR 引擎" />
                            <ComboBox x:Name="OcrEngineComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="windows-media-ocr">系统内置 OCR（免安装，默认开箱即用）</ComboBoxItem>
                                <ComboBoxItem Tag="enhanced-tesseract">增强本地 OCR（Tesseract 多轮识别）</ComboBoxItem>
                                <ComboBoxItem Tag="tesseract-cli">兼容模式 OCR（单轮 Tesseract）</ComboBoxItem>
                            </ComboBox>

                            <TextBlock x:Name="TesseractPathLabelTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="Tesseract 路径" />
                            <TextBox x:Name="TesseractPathTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="OCR 语言" />
                            <ComboBox x:Name="TesseractLanguageComboBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="chi_sim+eng">简体中文 + 英文</ComboBoxItem>
                                <ComboBoxItem Tag="chi_sim">简体中文</ComboBoxItem>
                                <ComboBoxItem Tag="eng">英文</ComboBoxItem>
                                <ComboBoxItem Tag="jpn">日文</ComboBoxItem>
                                <ComboBoxItem Tag="kor">韩文</ComboBoxItem>
                            </ComboBox>

                            <Border Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Padding="14"
                                    Background="#FF161E2C"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="默认推荐使用系统内置 OCR 先开箱即用；如果你后续想要更强本地识别，再切换到 Tesseract 相关方案。OCR 语言建议保留 chi_sim+eng。" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="OCR 测试" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="TestOcrButton"
                                                Style="{StaticResource SectionActionButtonStyle}"
                                                Click="TestOcrButton_OnClick">测试 OCR</Button>
                                    </WrapPanel>
                                    <TextBox x:Name="OcrTestResultTextBox"
                                             MinHeight="130"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <ScrollViewer x:Name="TranslationSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="翻译来源" />
                            <ComboBox x:Name="TranslationProviderComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="local">本地轻量翻译</ComboBoxItem>
                                <ComboBoxItem Tag="api">API 翻译</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="目标语言" />
                            <ComboBox x:Name="TargetLanguageComboBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="zh-CN">简体中文</ComboBoxItem>
                                <ComboBoxItem Tag="en">英语</ComboBoxItem>
                                <ComboBoxItem Tag="ja">日语</ComboBoxItem>
                                <ComboBoxItem Tag="ko">韩语</ComboBoxItem>
                            </ComboBox>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Padding="14"
                                    Background="#FF161E2C"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="默认使用本地轻量翻译；如果你希望强制走自己的 DeepSeek 或其他兼容接口，可以直接切换到 API 翻译。" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="API 配置管理" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="#FFCBD5E1"
                                                       TextWrapping="Wrap"
                                                       Text="可以保存多套不同厂商或模型的翻译接口。点击添加后才会显示填写项，删除会直接清掉这套本地记录。" />
                                        </StackPanel>

                                        <WrapPanel Grid.Column="1"
                                                   HorizontalAlignment="Right">
                                            <Button x:Name="AddApiProfileButton"
                                                    Style="{StaticResource SectionActionButtonStyle}"
                                                    Click="AddApiProfileButton_OnClick">+ 添加配置</Button>
                                            <Button x:Name="DeleteApiProfileButton"
                                                    Style="{StaticResource SectionActionButtonStyle}"
                                                    Click="DeleteApiProfileButton_OnClick">删除当前</Button>
                                        </WrapPanel>
                                    </Grid>

                                    <StackPanel x:Name="EmptyApiProfileStatePanel"
                                                Margin="0,14,0,0">
                                        <TextBlock Foreground="#FFCBD5E1"
                                                   TextWrapping="Wrap"
                                                   Text="当前还没有 API 配置，点击“添加配置”后再填写名称、接口地址、API Key 和模型。" />
                                    </StackPanel>

                                    <Grid x:Name="ApiProfileManagerGrid"
                                          Margin="0,14,0,0"
                                          Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,12"
                                                   VerticalAlignment="Center"
                                                   Text="配置卡片" />
                                        <ListBox x:Name="ApiProfileCardsListBox"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,12"
                                                 SelectedValuePath="Id"
                                                 SelectionChanged="ApiProfileCardsListBox_OnSelectionChanged"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border MinWidth="180"
                                                            Margin="0,0,10,10"
                                                            Padding="12"
                                                            Background="{DynamicResource Theme.Brush.CardBackground}"
                                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Row="1"
                                                                       Margin="0,6,0,0"
                                                                       Text="{Binding Model}"
                                                                       Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Text="配置名称" />
                                        <TextBox x:Name="ApiProfileNameTextBox"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,12" />

                                        <TextBlock x:Name="BaseUrlLabelTextBlock"
                                                   Grid.Row="2"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,12"
                                                   VerticalAlignment="Center"
                                                   Text="接口地址" />
                                        <TextBox x:Name="BaseUrlTextBox"
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,12" />

                                        <TextBlock x:Name="ApiKeyLabelTextBlock"
                                                   Grid.Row="3"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,12"
                                                   VerticalAlignment="Center"
                                                   Text="API Key" />
                                        <Grid x:Name="ApiKeyEditorGrid"
                                              Grid.Row="3"
                                              Grid.Column="1"
