                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="这里放主窗口、托盘和系统级操作快捷键；截图与贴图命令快捷键在“执行操作与快捷键”目录里设置。" />
                                    <Grid Margin="0,14,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Text="打开主菜单" />
                                        <TextBox x:Name="HotkeyShowMainWindowTextBox"
                                                 Grid.Column="1"
                                                 Margin="0,0,12,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource CompactRoundedButtonStyle}"
                                                Width="78"
                                                Height="32"
                                                Margin="0,0,12,0"
                                                Click="RecordShowMainWindowHotkeyButton_OnClick">录制</Button>
                                        <Button Grid.Column="3"
                                                Style="{StaticResource CompactRoundedButtonStyle}"
                                                Width="78"
                                                Height="32"
                                                Click="ClearShowMainWindowHotkeyButton_OnClick">清空</Button>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Margin="0,8,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="退出软件" />
                                        <TextBox x:Name="HotkeyExitApplicationTextBox"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,8,12,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Row="1"
                                                Grid.Column="2"
                                                Style="{StaticResource CompactRoundedButtonStyle}"
                                                Width="78"
                                                Height="32"
                                                Margin="0,8,12,0"
                                                Click="RecordExitApplicationHotkeyButton_OnClick">录制</Button>
                                        <Button Grid.Row="1"
                                                Grid.Column="3"
                                                Style="{StaticResource CompactRoundedButtonStyle}"
                                                Width="78"
                                                Height="32"
                                                Margin="0,8,0,0"
                                                Click="ClearExitApplicationHotkeyButton_OnClick">清空</Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="AppearanceSettingsSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel Margin="0,0,8,0">
                            <Border Margin="0,0,0,16"
                                    Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="主题配色" />
                                    <ComboBox x:Name="ThemeComboBox"
                                              Width="320"
                                              Margin="0,12,0,0"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="ThemeComboBox_OnSelectionChanged"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="ocean-blue">深海蓝</ComboBoxItem>
                                        <ComboBoxItem Tag="forest-green">松林绿</ComboBoxItem>
                                        <ComboBoxItem Tag="teal-cyan">青岚色</ComboBoxItem>
                                        <ComboBoxItem Tag="sunset-orange">落日橙</ComboBoxItem>
                                        <ComboBoxItem Tag="ruby-red">绯红色</ComboBoxItem>
                                        <ComboBoxItem Tag="amber-gold">琥珀金</ComboBoxItem>
                                        <ComboBoxItem Tag="rose-pink">玫瑰粉</ComboBoxItem>
                                        <ComboBoxItem Tag="indigo-night">靛夜紫</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="选择主题后会立即切换，主菜单、托盘菜单、翻译浮窗和截图操作条会同步更新为当前配色。" />
                                </StackPanel>
                            </Border>

                            <Border Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="外观说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="主题配色只影响界面显示风格，不会改动 OCR、翻译接口或截图功能逻辑。可以随时切换成你更顺眼的方案。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="TraySettingsSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel Margin="0,0,8,0">
                            <CheckBox x:Name="LaunchAtStartupCheckBox"
                                      Margin="0,0,0,16"
                                      Content="开机自启（登录当前 Windows 账户后自动启动 SnapCat）" />

                            <Border Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="托盘左键默认动作" />
                                    <ComboBox x:Name="TrayLeftClickActionComboBox"
                                              Width="320"
                                              Margin="0,12,0,0"
                                              HorizontalAlignment="Left"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="CaptureAndPin">自由框选并固定到屏幕</ComboBoxItem>
                                        <ComboBoxItem Tag="CaptureAndTranslate">自由框选后自动翻译</ComboBoxItem>
                                        <ComboBoxItem Tag="CaptureAndWaitForAction">自由框选后等待操作选择</ComboBoxItem>
                                        <ComboBoxItem Tag="CaptureAndSave">自由框选并保存到默认位置</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="手动启动时主窗口会正常显示；只有开机自启时才会带托盘参数启动。托盘左键默认动作也可以在这里直接改。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="HistorySection"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="0,0,0,16">
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="RefreshHistoryButton_OnClick">刷新历史</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="OpenHistoryDetailButton_OnClick">查看详情</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="OpenImageLocationButton_OnClick">打开截图位置</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="DeleteHistoryButton_OnClick">删除选中</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ClearHistoryButton_OnClick">清空历史</Button>
                        </WrapPanel>

                        <Border Grid.Row="1"
                                Margin="0,0,0,16"
                                Padding="12"
                                Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="历史记录保留天数" />
                                <TextBox x:Name="HistoryRetentionDaysTextBox"
                                         Grid.Column="1"
                                         Width="76"
                                         Margin="12,0,0,0"
                                         HorizontalAlignment="Left"
                                         VerticalContentAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Margin="12,0,12,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                           Text="填 3 / 5 / 7 或自定义天数，填 0 表示不自动清理历史。" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="最近记录">
                                <ListBox x:Name="HistoryListBox"
                                         Style="{StaticResource HistoryListBoxStyle}"
                                         SelectionChanged="HistoryListBox_OnSelectionChanged"
                                         MouseDoubleClick="HistoryListBox_OnMouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Summary}"
                                                       Margin="0,0,22,0"
                                                       MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="记录预览">
                                <Grid Margin="8">
                                    <TextBlock x:Name="HistoryPreviewEmptyTextBlock"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="#FFCBD5E1"
                                               Text="当前还没有可预览的历史记录。完成一次截图操作后会显示在这里。" />

                                    <ScrollViewer x:Name="HistoryPreviewPanelScrollViewer"
                                                  Style="{StaticResource HistoryScrollViewerStyle}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Visibility="Collapsed">
                                        <Grid x:Name="HistoryPreviewGrid">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="HistoryPreviewTitleTextBlock"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />

                                            <TextBlock x:Name="HistoryPreviewMetaTextBlock"
                                                       Grid.Row="1"
                                                       Margin="0,6,0,0"
                                                       Foreground="#FFCBD5E1"
                                                       TextWrapping="Wrap" />

                                            <Border Grid.Row="2"
                                                    Margin="0,12,0,0"
                                                    Padding="10"
                                                    Background="#FF333333"
                                                    BorderBrush="#FF3F3F46"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock x:Name="HistoryPreviewStatusTextBlock"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="3"
                                                    Margin="0,12,0,0"
                                                    Padding="12"
                                                    Background="#FF2B2B2B"
                                                    BorderBrush="#FF3F3F46"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <Grid>
                                                    <TextBlock x:Name="HistoryPreviewUnavailableTextBlock"
                                                               Foreground="#FFCBD5E1"
                                                               TextWrapping="Wrap"
                                                               Visibility="Collapsed" />
                                                    <ScrollViewer x:Name="HistoryPreviewScrollViewer"
                                                                  Style="{StaticResource HistoryScrollViewerStyle}"
                                                                  HorizontalScrollBarVisibility="Auto"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  MaxHeight="180"
                                                                  Visibility="Collapsed">
                                                        <Image x:Name="HistoryPreviewImage"
                                                               Stretch="None"
                                                               SnapsToDevicePixels="True"
                                                               UseLayoutRounding="True" />
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="4"
                                                  Margin="0,12,0,0"
                                                  VerticalAlignment="Top">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <GroupBox x:Name="HistoryPrimaryGroupBox">
                                                    <Border Margin="0,4,0,0"
                                                            Padding="12"
                                                            MinHeight="170"
                                                            MaxHeight="220"
                                                            Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBox x:Name="HistoryPrimaryTextBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalContentAlignment="Top"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Disabled" />
                                                    </Border>
                                                </GroupBox>

                                                <GroupBox x:Name="HistorySecondaryGroupBox" Grid.Column="2">
                                                    <Border Margin="0,4,0,0"
                                                            Padding="12"
                                                            MinHeight="170"
                                                            MaxHeight="220"
                                                            Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBox x:Name="HistorySecondaryTextBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalContentAlignment="Top"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Disabled" />
                                                    </Border>
                                                </GroupBox>
                                            </Grid>

                                            <WrapPanel Grid.Row="5"
                                                       Margin="0,16,0,0"
                                                       HorizontalAlignment="Right">
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,8,8"
                                                        Click="CopyHistoryPrimaryButton_OnClick">复制左侧</Button>
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,8,8"
                                                        Click="CopyHistorySecondaryButton_OnClick">复制右侧</Button>
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,0,8"
                                                        Click="OpenHistoryDetailButton_OnClick">完整详情</Button>
                                            </WrapPanel>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </Grid>

                    <Grid x:Name="PinnedImagesSection"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="0,0,0,16">
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="RefreshPinnedImagesButton_OnClick">刷新贴图</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="SelectAllPinnedImagesButton_OnClick">全选</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="DeleteSelectedPinnedImagesButton_OnClick">删除选中</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="DeleteAllPinnedImagesButton_OnClick">全部删除</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ShowAllPinnedImagesButton_OnClick">显示全部</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="HideAllPinnedImagesButton_OnClick">隐藏全部</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ShowUngroupedPinnedImagesButton_OnClick">显示未成组</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ShowPinnedGroupOneButton_OnClick">显示贴图组 1</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ShowPinnedGroupTwoButton_OnClick">显示贴图组 2</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ShowPinnedGroupThreeButton_OnClick">显示贴图组 3</Button>
                        </WrapPanel>

                        <GroupBox Grid.Row="1" Header="窗口所有截图和贴图组">
                            <ListBox x:Name="PinnedImagesListBox"
                                     Style="{StaticResource HistoryListBoxStyle}"
                                     SelectionMode="Extended"
                                     PreviewMouseRightButtonDown="PinnedImagesListBox_OnPreviewMouseRightButtonDown">
                                <ListBox.ContextMenu>
                                    <ContextMenu Style="{StaticResource MainContextMenuStyle}">
                                        <MenuItem Header="指定为未成组" Style="{StaticResource MainContextMenuItemStyle}" Click="AssignPinnedImagesToUngroupedMenuItem_OnClick" />
                                        <MenuItem Header="指定到贴图组 1" Style="{StaticResource MainContextMenuItemStyle}" Click="AssignPinnedImagesToGroupOneMenuItem_OnClick" />
                                        <MenuItem Header="指定到贴图组 2" Style="{StaticResource MainContextMenuItemStyle}" Click="AssignPinnedImagesToGroupTwoMenuItem_OnClick" />
                                        <MenuItem Header="指定到贴图组 3" Style="{StaticResource MainContextMenuItemStyle}" Click="AssignPinnedImagesToGroupThreeMenuItem_OnClick" />
                                        <Separator Style="{StaticResource MainContextMenuSeparatorStyle}" />
                                        <MenuItem Header="删除选中贴图" Style="{StaticResource MainContextMenuItemStyle}" Click="DeleteSelectedPinnedImagesMenuItem_OnClick" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,22,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="64"
                                                    Height="44"
                                                    Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Border>
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding Summary}"
                                                           Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                    </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Margin="0,22,0,0"
                        Padding="12"
                        Background="#FF2B2B2B"
                        BorderBrush="#FF4B5563"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock x:Name="StatusTextBlock"
                               Foreground="#FFE5E7EB"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
    </Grid>
</Window>
