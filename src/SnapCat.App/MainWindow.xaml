<Window x:Class="SnapCat.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SnapCat"
        Icon="Assets/SnapCat.png"
        Background="Transparent"
        WindowStyle="None"
        Width="1320"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonPressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="SectionActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="CompactRoundedButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
        </Style>

        <Style x:Key="InlineIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.AccentSoft}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Theme.Brush.AccentSoftPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainWindowScrollThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Margin="1"
                                Background="{DynamicResource Theme.Brush.ScrollThumb}"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CanContentScroll" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Orientation="Vertical"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,8,0,0"
                                       Orientation="Horizontal"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />

                            <Border x:Name="ScrollCorner"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="8,8,0,0"
                                    Background="{DynamicResource Theme.Brush.ScrollTrack}"
                                    CornerRadius="4"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="ComputedVerticalScrollBarVisibility" Value="Visible" />
                                    <Condition Property="ComputedHorizontalScrollBarVisibility" Value="Visible" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ScrollCorner" Property="Visibility" Value="Visible" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.ScrollTrack}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{DynamicResource Theme.Brush.ScrollTrack}"
                                CornerRadius="5">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MainWindowScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="10" />
                                <Setter Property="VerticalAlignment" Value="Bottom" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.ReadOnlyBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PasswordBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                <Setter TargetName="PasswordBoxBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PasswordBoxBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,0,40,0" />
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="12"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  IsHitTestVisible="False" />
                                                <Path Width="8"
                                                      Height="4"
                                                      Margin="0,0,14,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{DynamicResource Theme.Brush.TextMuted}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.6" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Margin="0,6,0,0"
                                            Padding="6"
                                            Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Theme.Brush.SurfaceBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="HistoryListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="Padding" Value="0,0,6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Style="{StaticResource HistoryScrollViewerStyle}"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.SurfaceAltBackground}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.ButtonBorder}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Theme.Brush.Accent}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Theme.Brush.AccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2"
                                    Margin="0,10,0,0"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14" />
                            <Border Margin="16,0,16,0"
                                    Padding="10,0"
                                    Background="{DynamicResource Theme.Brush.WindowBackground}"
                                    HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Foreground" Value="{DynamicResource Theme.Brush.TextPrimary}" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              Margin="14,18,14,14" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid Margin="12,6,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Width="18"
                           Height="18"
                           Source="Assets/SnapCat.png"
                           Stretch="Uniform" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="SnapCat" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="MinimizeButton_OnClick"
                            Content="-" />
                    <Button x:Name="MaximizeRestoreButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,8,0"
                            Click="MaximizeRestoreButton_OnClick"
                            Content="□" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="CloseWindowButton_OnClick"
                            Content="×" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="SnapCat" />
                    <TextBlock x:Name="VersionTextBlock"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource Theme.Brush.TextMuted}" />
                    <TextBlock Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                               Text="自由框选截图、OCR、翻译和贴图操作现在都在一个主窗口里整理查看。" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,22,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="12"
                            Background="{DynamicResource Theme.Brush.CardBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.Highlight}"
                                       Text="功能项类" />
                            <Button x:Name="OcrNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="OcrSettings"
                                    Click="NavigationButton_OnClick">OCR 设置</Button>
                            <Button x:Name="TranslationNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="TranslationSettings"
                                    Click="NavigationButton_OnClick">翻译设置</Button>
                            <Button x:Name="HistoryNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="History"
                                    Click="NavigationButton_OnClick">历史记录</Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="{DynamicResource Theme.Brush.CardBackground}"
                            BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource Theme.Brush.HighlightAlt}"
                                       Text="系统设置类" />
                            <Button x:Name="CaptureSettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="CaptureSettings"
                                    Click="NavigationButton_OnClick">截图与快捷键</Button>
                            <Button x:Name="AppearanceSettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="AppearanceSettings"
                                    Click="NavigationButton_OnClick">外观主题</Button>
                            <Button x:Name="TraySettingsNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="TraySettings"
                                    Click="NavigationButton_OnClick">托盘与启动</Button>
                            <Button x:Name="StatusNavButton"
                                    Style="{StaticResource SidebarButtonStyle}"
                                    Tag="Status"
                                    Click="NavigationButton_OnClick">运行状态</Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="4"
                        Margin="0,16,0,0"
                        Padding="12"
                        Background="{DynamicResource Theme.Brush.CardBackground}"
                        BorderBrush="{DynamicResource Theme.Brush.CardBorder}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource Theme.Brush.TextPrimary}"
                               Text="左侧只负责切换分类，右侧直接显示当前内容，不再弹出新的设置窗口。" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource Theme.Brush.WindowBackground}"
                BorderBrush="{DynamicResource Theme.Brush.WindowBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SectionTitleTextBlock"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Theme.Brush.TextPrimary}" />
                        <TextBlock x:Name="SectionDescriptionTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Theme.Brush.TextMuted}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top">
                        <Button x:Name="SaveSettingsButton"
                                Style="{StaticResource RoundedButtonStyle}"
                                Width="122"
                                Height="38"
                                Margin="0,0,10,0"
                                Visibility="Collapsed"
                                Click="SaveSettingsButton_OnClick">保存当前设置</Button>
                        <Button x:Name="CaptureButton"
                                Style="{StaticResource RoundedButtonStyle}"
                                Width="0"
                                Height="0"
                                MinWidth="0"
                                Padding="0"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                Click="CaptureButton_OnClick">开始自由框选</Button>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,22,0,0">
                    <ScrollViewer x:Name="StatusSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel>
                            <Border Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="当前配置摘要" />
                                    <TextBlock x:Name="SettingsSummaryTextBlock"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="#FF172033"
                                    BorderBrush="#FF3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock x:Name="EnvironmentCheckTitleTextBlock"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Text="启动检查" />
                                    <TextBlock x:Name="EnvironmentCheckTextBlock"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="使用建议" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="功能项类主要放 OCR、翻译和历史记录；系统设置类主要放快捷键、外观、托盘和运行状态。你现在可以在同一个窗口里完成查看、修改、测试和保存。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="OcrSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="BaseUrlLabelTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="OCR 引擎" />
                            <ComboBox x:Name="OcrEngineComboBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="windows-media-ocr">系统内置 OCR（免安装，默认开箱即用）</ComboBoxItem>
                                <ComboBoxItem Tag="enhanced-tesseract">增强本地 OCR（Tesseract 多轮识别）</ComboBoxItem>
                                <ComboBoxItem Tag="tesseract-cli">兼容模式 OCR（单轮 Tesseract）</ComboBoxItem>
                            </ComboBox>

                            <TextBlock x:Name="ApiKeyLabelTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="Tesseract 路径" />
                            <TextBox x:Name="TesseractPathTextBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="OCR 语言" />
                            <ComboBox x:Name="TesseractLanguageComboBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="chi_sim+eng">简体中文 + 英文</ComboBoxItem>
                                <ComboBoxItem Tag="chi_sim">简体中文</ComboBoxItem>
                                <ComboBoxItem Tag="eng">英文</ComboBoxItem>
                                <ComboBoxItem Tag="jpn">日文</ComboBoxItem>
                                <ComboBoxItem Tag="kor">韩文</ComboBoxItem>
                            </ComboBox>

                            <Border Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Padding="14"
                                    Background="#FF161E2C"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="默认推荐使用系统内置 OCR 先开箱即用；如果你后续想要更强本地识别，再切换到 Tesseract 相关方案。OCR 语言建议保留 chi_sim+eng。" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="OCR 测试" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="TestOcrButton"
                                                Style="{StaticResource SectionActionButtonStyle}"
                                                Click="TestOcrButton_OnClick">测试 OCR</Button>
                                    </WrapPanel>
                                    <TextBox x:Name="OcrTestResultTextBox"
                                             MinHeight="130"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <ScrollViewer x:Name="TranslationSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <Grid Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="接口地址" />
                            <TextBox x:Name="BaseUrlTextBox"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="API Key" />
                            <Grid x:Name="ApiKeyEditorGrid"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,0,0,12">
                                <PasswordBox x:Name="ApiKeyPasswordBox"
                                             Padding="14,9,44,9"
                                             PasswordChanged="ApiKeyPasswordBox_OnPasswordChanged" />
                                <TextBox x:Name="ApiKeyTextBox"
                                         Padding="14,9,44,9"
                                         Visibility="Collapsed"
                                         TextChanged="ApiKeyTextBox_OnTextChanged" />
                                <Button x:Name="ToggleApiKeyVisibilityButton"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource InlineIconButtonStyle}"
                                        Click="ToggleApiKeyVisibilityButton_OnClick"
                                        ToolTip="显示 API Key">
                                    <TextBlock x:Name="ApiKeyVisibilityIconTextBlock"
                                               FontSize="13"
                                               Text="👁" />
                                </Button>
                            </Grid>

                            <TextBlock x:Name="ModelLabelTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="模型" />
                            <TextBox x:Name="ModelTextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,0,0,12" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="翻译来源" />
                            <ComboBox x:Name="TranslationProviderComboBox"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="local">本地轻量翻译</ComboBoxItem>
                                <ComboBoxItem Tag="api">API 翻译</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="目标语言" />
                            <ComboBox x:Name="TargetLanguageComboBox"
                                      Grid.Row="4"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="zh-CN">简体中文</ComboBoxItem>
                                <ComboBoxItem Tag="en">英语</ComboBoxItem>
                                <ComboBoxItem Tag="ja">日语</ComboBoxItem>
                                <ComboBoxItem Tag="ko">韩语</ComboBoxItem>
                            </ComboBox>

                            <TextBlock x:Name="SystemPromptLabelTextBlock"
                                       Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="System Prompt" />
                            <TextBox x:Name="SystemPromptTextBox"
                                     Grid.Row="5"
                                     Grid.Column="1"
                                     Height="100"
                                     Margin="0,0,0,12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />

                            <Border Grid.Row="6"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Padding="14"
                                    Background="#FF161E2C"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#FFCBD5E1"
                                               TextWrapping="Wrap"
                                               Text="默认使用本地轻量翻译；如果你希望强制走自己的 DeepSeek 或其他兼容接口，可以直接切换到 API 翻译。" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="7"
                                    Grid.ColumnSpan="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="API 配置管理" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Foreground="#FFCBD5E1"
                                                       TextWrapping="Wrap"
                                                       Text="可以保存多套不同厂商或模型的翻译接口。点击添加后才会显示填写项，删除会直接清掉这套本地记录。" />
                                        </StackPanel>

                                        <WrapPanel Grid.Column="1"
                                                   HorizontalAlignment="Right">
                                            <Button x:Name="AddApiProfileButton"
                                                    Style="{StaticResource SectionActionButtonStyle}"
                                                    Click="AddApiProfileButton_OnClick">+ 添加配置</Button>
                                            <Button x:Name="DeleteApiProfileButton"
                                                    Style="{StaticResource SectionActionButtonStyle}"
                                                    Click="DeleteApiProfileButton_OnClick">删除当前</Button>
                                        </WrapPanel>
                                    </Grid>

                                    <StackPanel x:Name="EmptyApiProfileStatePanel"
                                                Margin="0,14,0,0">
                                        <TextBlock Foreground="#FFCBD5E1"
                                                   TextWrapping="Wrap"
                                                   Text="当前还没有 API 配置，点击“添加配置”后再填写名称、接口地址、API Key 和模型。" />
                                    </StackPanel>

                                    <Grid x:Name="ApiProfileManagerGrid"
                                          Margin="0,14,0,0"
                                          Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,12"
                                                   VerticalAlignment="Center"
                                                   Text="当前配置" />
                                        <ComboBox x:Name="ApiProfileComboBox"
                                                  Grid.Row="0"
                                                  Grid.Column="1"
                                                  Margin="0,0,0,12"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectionChanged="ApiProfileComboBox_OnSelectionChanged" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Margin="0,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Text="配置名称" />
                                        <TextBox x:Name="ApiProfileNameTextBox"
                                                 Grid.Row="1"
                                                 Grid.Column="1" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="8"
                                    Grid.ColumnSpan="2"
                                    Margin="0,18,0,0"
                                    Padding="14"
                                    Background="#FF111827"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="翻译测试" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="TestApiConnectionButton"
                                                Style="{StaticResource SectionActionButtonStyle}"
                                                Click="TestApiConnectionButton_OnClick">测试 API 连接</Button>
                                        <Button x:Name="TestTranslationButton"
                                                Style="{StaticResource SectionActionButtonStyle}"
                                                Click="TestTranslationButton_OnClick">测试翻译</Button>
                                    </WrapPanel>
                                    <TextBox x:Name="TranslationTestResultTextBox"
                                             MinHeight="130"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <ScrollViewer x:Name="CaptureSettingsSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="0,0,12,12"
                                           VerticalAlignment="Top"
                                           Text="快捷键：固定到屏幕" />
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="HotkeyCaptureAndPinTextBox"
                                             Margin="0,0,12,0"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            Click="RecordPinHotkeyButton_OnClick">录制</Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Click="ClearPinHotkeyButton_OnClick">清空</Button>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,12,12"
                                           VerticalAlignment="Top"
                                           Text="快捷键：自动翻译" />
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="HotkeyCaptureAndTranslateTextBox"
                                             Margin="0,0,12,0"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            Click="RecordTranslateHotkeyButton_OnClick">录制</Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Click="ClearTranslateHotkeyButton_OnClick">清空</Button>
                                </Grid>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,0,12,12"
                                           VerticalAlignment="Top"
                                           Text="快捷键：等待操作" />
                                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="HotkeyCaptureAndWaitTextBox"
                                             Margin="0,0,12,0"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Margin="0,0,12,0"
                                            Click="RecordWaitHotkeyButton_OnClick">录制</Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource CompactRoundedButtonStyle}"
                                            Width="78"
                                            Height="32"
                                            Click="ClearWaitHotkeyButton_OnClick">清空</Button>
                                </Grid>
                            </Grid>

                            <WrapPanel Margin="0,4,0,0">
                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                        Width="130"
                                        Height="32"
                                        Click="RestoreDefaultHotkeysButton_OnClick">还原默认快捷键</Button>
                            </WrapPanel>

                            <Border Margin="0,8,0,0"
                                    Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="快捷键状态" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="点击“录制”后直接按下组合键，按 Esc 取消录制。推荐使用 Ctrl / Alt / Shift / Win 与其他键组合。" />
                                    <TextBlock x:Name="HotkeyValidationTextBlock"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="AppearanceSettingsSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel Margin="0,0,8,0">
                            <Border Margin="0,0,0,16"
                                    Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="主题配色" />
                                    <ComboBox x:Name="ThemeComboBox"
                                              Width="320"
                                              Margin="0,12,0,0"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="ThemeComboBox_OnSelectionChanged"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="ocean-blue">深海蓝</ComboBoxItem>
                                        <ComboBoxItem Tag="forest-green">松林绿</ComboBoxItem>
                                        <ComboBoxItem Tag="teal-cyan">青岚色</ComboBoxItem>
                                        <ComboBoxItem Tag="sunset-orange">落日橙</ComboBoxItem>
                                        <ComboBoxItem Tag="ruby-red">绯红色</ComboBoxItem>
                                        <ComboBoxItem Tag="amber-gold">琥珀金</ComboBoxItem>
                                        <ComboBoxItem Tag="rose-pink">玫瑰粉</ComboBoxItem>
                                        <ComboBoxItem Tag="indigo-night">靛夜紫</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="选择主题后会立即切换，主菜单、托盘菜单、翻译浮窗和截图操作条会同步更新为当前配色。" />
                                </StackPanel>
                            </Border>

                            <Border Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="外观说明" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="主题配色只影响界面显示风格，不会改动 OCR、翻译接口或截图功能逻辑。可以随时切换成你更顺眼的方案。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="TraySettingsSection"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <StackPanel Margin="0,0,8,0">
                            <CheckBox x:Name="LaunchAtStartupCheckBox"
                                      Margin="0,0,0,16"
                                      Content="开机自启（登录当前 Windows 账户后自动启动 SnapCat）" />

                            <Border Padding="14"
                                    Background="{DynamicResource Theme.Brush.SurfaceBackground}"
                                    BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="托盘左键默认动作" />
                                    <ComboBox x:Name="TrayLeftClickActionComboBox"
                                              Width="320"
                                              Margin="0,12,0,0"
                                              HorizontalAlignment="Left"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="CaptureAndPin">自由框选并固定到屏幕</ComboBoxItem>
                                        <ComboBoxItem Tag="CaptureAndTranslate">自由框选后自动翻译</ComboBoxItem>
                                        <ComboBoxItem Tag="CaptureAndWaitForAction">自由框选后等待操作选择</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="{DynamicResource Theme.Brush.TextSecondary}"
                                               TextWrapping="Wrap"
                                               Text="手动启动时主窗口会正常显示；只有开机自启时才会带托盘参数启动。托盘左键默认动作也可以在这里直接改。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="HistorySection"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel Margin="0,0,0,16">
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="RefreshHistoryButton_OnClick">刷新历史</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="OpenHistoryDetailButton_OnClick">查看详情</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="OpenImageLocationButton_OnClick">打开截图位置</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="DeleteHistoryButton_OnClick">删除选中</Button>
                            <Button Style="{StaticResource SectionActionButtonStyle}"
                                    Click="ClearHistoryButton_OnClick">清空历史</Button>
                        </WrapPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="最近记录">
                                <ListBox x:Name="HistoryListBox"
                                         Style="{StaticResource HistoryListBoxStyle}"
                                         SelectionChanged="HistoryListBox_OnSelectionChanged"
                                         MouseDoubleClick="HistoryListBox_OnMouseDoubleClick">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Summary}"
                                                       Margin="0,0,22,0"
                                                       MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="记录预览">
                                <Grid Margin="8">
                                    <TextBlock x:Name="HistoryPreviewEmptyTextBlock"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="#FFCBD5E1"
                                               Text="当前还没有可预览的历史记录。完成一次截图操作后会显示在这里。" />

                                    <ScrollViewer x:Name="HistoryPreviewPanelScrollViewer"
                                                  Style="{StaticResource HistoryScrollViewerStyle}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Visibility="Collapsed">
                                        <Grid x:Name="HistoryPreviewGrid">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="HistoryPreviewTitleTextBlock"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />

                                            <TextBlock x:Name="HistoryPreviewMetaTextBlock"
                                                       Grid.Row="1"
                                                       Margin="0,6,0,0"
                                                       Foreground="#FFCBD5E1"
                                                       TextWrapping="Wrap" />

                                            <Border Grid.Row="2"
                                                    Margin="0,12,0,0"
                                                    Padding="10"
                                                    Background="#FF333333"
                                                    BorderBrush="#FF3F3F46"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock x:Name="HistoryPreviewStatusTextBlock"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="3"
                                                    Margin="0,12,0,0"
                                                    Padding="12"
                                                    Background="#FF2B2B2B"
                                                    BorderBrush="#FF3F3F46"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <Grid>
                                                    <TextBlock x:Name="HistoryPreviewUnavailableTextBlock"
                                                               Foreground="#FFCBD5E1"
                                                               TextWrapping="Wrap"
                                                               Visibility="Collapsed" />
                                                    <ScrollViewer x:Name="HistoryPreviewScrollViewer"
                                                                  Style="{StaticResource HistoryScrollViewerStyle}"
                                                                  HorizontalScrollBarVisibility="Auto"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  MaxHeight="180"
                                                                  Visibility="Collapsed">
                                                        <Image x:Name="HistoryPreviewImage"
                                                               Stretch="None"
                                                               SnapsToDevicePixels="True"
                                                               UseLayoutRounding="True" />
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="4"
                                                  Margin="0,12,0,0"
                                                  VerticalAlignment="Top">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <GroupBox x:Name="HistoryPrimaryGroupBox">
                                                    <Border Margin="0,4,0,0"
                                                            Padding="12"
                                                            MinHeight="170"
                                                            MaxHeight="220"
                                                            Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBox x:Name="HistoryPrimaryTextBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalContentAlignment="Top"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Disabled" />
                                                    </Border>
                                                </GroupBox>

                                                <GroupBox x:Name="HistorySecondaryGroupBox" Grid.Column="2">
                                                    <Border Margin="0,4,0,0"
                                                            Padding="12"
                                                            MinHeight="170"
                                                            MaxHeight="220"
                                                            Background="{DynamicResource Theme.Brush.ReadOnlyBackground}"
                                                            BorderBrush="{DynamicResource Theme.Brush.ButtonBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBox x:Name="HistorySecondaryTextBox"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 Padding="0"
                                                                 AcceptsReturn="True"
                                                                 IsReadOnly="True"
                                                                 TextWrapping="Wrap"
                                                                 VerticalContentAlignment="Top"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Disabled" />
                                                    </Border>
                                                </GroupBox>
                                            </Grid>

                                            <WrapPanel Grid.Row="5"
                                                       Margin="0,16,0,0"
                                                       HorizontalAlignment="Right">
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,8,8"
                                                        Click="CopyHistoryPrimaryButton_OnClick">复制左侧</Button>
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,8,8"
                                                        Click="CopyHistorySecondaryButton_OnClick">复制右侧</Button>
                                                <Button Style="{StaticResource CompactRoundedButtonStyle}"
                                                        Width="108"
                                                        Height="32"
                                                        Margin="0,0,0,8"
                                                        Click="OpenHistoryDetailButton_OnClick">完整详情</Button>
                                            </WrapPanel>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Margin="0,22,0,0"
                        Padding="12"
                        Background="#FF2B2B2B"
                        BorderBrush="#FF4B5563"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock x:Name="StatusTextBlock"
                               Foreground="#FFE5E7EB"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
    </Grid>
</Window>
